# Provider selection: "portkey" (default) or "mock" (offline, no API key needed)
ANIMATION_PROVIDER=portkey

# Portkey / OpenRouter
PORTKEY_API_KEY=31VDlDmCEYmc+zIalPAZ76FPsQzc
PORTKEY_BASE_URL=https://api.portkey.ai/v1

# Leave these two empty when OPENROUTER_MODEL already carries the @slug prefix
# (see below) — Portkey reads the integration straight from the model field.
PORTKEY_PROVIDER_SLUG=
PORTKEY_VIRTUAL_KEY=

# Use the exact string shown in the Portkey model picker, slug included.
OPENROUTER_MODEL=@google/gemini-3.5-flash

# CORS — comma separated list of origins allowed to call this API
CORS_ALLOWED_ORIGINS=https://silver-zebra-pj4v5jv5jv65f7p9-5173.app.github.dev

# Timeouts (seconds)
PORTKEY_TIMEOUT_SECONDS=20
ANIMATION_REQUEST_TIMEOUT_SECONDS=25
